{
  "enabledMcpjsonServers": [
    "github",
    "playwright",
    "postgres-dev",
    "postgres-prod"
  ],
  "disabledMcpjsonServers": [
    "context7",
    "postgres-staging"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard-local-models.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/meshkit-errors.sh"
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/no-ai-attribution.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "tools/hooks/helm-chart-audit.py"
          }
        ]
      }
    ]
  },
  "additionalDirectories": [
    "../schemas"
  ],
  "permissions": {
    "allow": [
      "mcp__playwright__browser_navigate"
    ]
  }
}
