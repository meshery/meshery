{
  "schemaVersion": "relationships.meshery.io/v1alpha3",
  "version": "v1.0.0",
  "kind": "Edge",
  "type": "Non-binding",
  "subType": "Network",
  "metadata": {
    "description": "Visualizes the message flow from an SNS Topic to a subscribing SQS Queue."
  },
  "selectors": [
    {
      "allow": {
        "from": [
          {
            "kind": "Topic",
            "model": "aws-sns-controller"
          }
        ],
        "to": [
          {
            "kind": "Queue",
            "model": "aws-sqs-controller"
          }
        ]
      }
    }
  ]
}
