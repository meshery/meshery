{
  "schemaVersion": "core.meshery.io/v1beta1",
  "version": "v1.0.0",
  "kind": "hierarchical",
  "type": "parent",
  "subType": "inventory",
  "metadata": {
    "description": "A Flux Kustomization that references a GitRepository as its source."
  },
  "model": {
    "name": "flux"
  },
  "id": "00000000-0000-0000-0000-000000000000",
  "selectors": [
    {
      "allow": {
        "from": [
          {
            "kind": "Kustomization",
            "model": "flux",
            "patch": {
              "patchStrategy": "replace",
              "mutatorRef": [["configuration", "spec", "sourceRef", "name"]],
              "description": "Kustomization references the GitRepository as its source."
            }
          }
        ],
        "to": [
          {
            "kind": "GitRepository",
            "model": "flux",
            "patch": {
              "patchStrategy": "replace",
              "mutatedRef": [["displayName"]],
              "description": "GitRepository is the source for the Kustomization."
            }
          }
        ]
      },
      "deny": {}
    }
  ]
}