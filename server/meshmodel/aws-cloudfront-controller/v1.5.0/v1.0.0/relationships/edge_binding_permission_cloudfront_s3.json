{
  "schemaVersion": "relationships.meshery.io/v1alpha3",
  "version": "v1.0.0",
  "kind": "RelationshipDefinition",
  "metadata": {
    "description": "S3 to CloudFront Permission Binding"
  },
  "model": {
    "name": "aws-cloudfront-controller",
    "version": "v1.5.0"
  },
  "type": "binding",
  "subType": "permission",
  "evaluationQuery": "edge_binding_permission_relationship",
  "selectors": [
    {
      "allow": {
        "from": [
          {
            "model": "aws-s3-controller",
            "kind": "Bucket",
            "patch": {
              "mutatorRef": [
                [
                  "configuration",
                  "name"
                ]
              ],
              "patchStrategy": "replace"
            }
          }
        ],
        "to": [
          {
            "model": "aws-cloudfront-controller",
            "kind": "Distribution",
            "patch": {
              "mutatedRef": [
                [
                  "configuration",
                  "spec",
                  "distributionConfig",
                  "origins",
                  "items",
                  "0",
                  "domainName"
                ]
              ],
              "patchStrategy": "replace"
            }
          }
        ]
      }
    }
  ]
}
