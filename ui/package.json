{
  "name": "meshery-ui",
  "version": "1.0.0",
  "description": "collaborative management plane",
  "main": "index.js",
  "scripts": {
    "dev": "npm run lint:fix && node ui_dev_server.js",
    "lint": "eslint --cache --ext .js,.jsx,.ts,.tsx .",
    "lint:ui-kit": "eslint --cache --quiet --ext .js,.jsx,.ts,.tsx .",
    "lint:fix": "eslint --cache --fix --ext .js,.jsx,.ts,.tsx .",
    "format": "npx prettier --write \"**/*.{ts,tsx,js,jsx,md,json}\"",
    "build": "npm run clean && cross-env next build",
    "build-fast": "cross-env NODE_OPTIONS='--max-old-space-size=12288' next build",
    "start": "NODE_ENV=production node ui_dev_server.js",
    "export": "node scripts/export-shim.js",
    "export-playground": "npm run clean && cross-env PLAYGROUND=true next build && rm -rf playground && mv out playground",
    "test:e2e": "ALLURE_LABEL_project=Meshery ALLURE_LABEL_type=e2e PLAYWRIGHT_JSON_OUTPUT_NAME=results.json npx playwright test  --reporter json",
    "test:e2e:relationship": "ALLURE_LABEL_project=Meshery ALLURE_LABEL_type=e2e PLAYWRIGHT_JSON_OUTPUT_NAME=results.json npx playwright test --project=chromium-local-provider --grep @relationship --reporter json",
    "test:e2e:ci:local": "ALLURE_LABEL_project=Meshery ALLURE_LABEL_type=e2e npx playwright test --project=chromium-local-provider",
    "test:e2e:ci:full": "ALLURE_LABEL_project=Meshery ALLURE_LABEL_type=e2e npx playwright test --project=chromium-local-provider --project=chromium-meshery-provider",
    "test:e2e:chromium": "ALLURE_LABEL_project=Meshery ALLURE_LABEL_type=e2e npx playwright test --project=chromium-local-provider",
    "test:e2e:codegen": "npx playwright codegen --load-storage=playwright/.auth/user.json http://localhost:9081/extension/meshmap",
    "test:e2e:fast": "npx playwright test --project=firefox --grep-invert @slow",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "relay": "relay-compiler",
    "prepare": "cd .. && { [ -e .git ] && husky ui/.husky || true; }",
    "postinstall": "patch-package",
    "clean": "rm -rf .next,out",
    "audit:mui": "node scripts/audit-mui.js",
    "audit:hex": "node scripts/audit-hex.js",
    "audit:size": "node scripts/audit-size.js",
    "audit:all": "node scripts/audit-mui.js && node scripts/audit-hex.js && node scripts/audit-size.js"
  },
  "keywords": [],
  "author": "Meshery Authors",
  "repository": "https://github.com/meshery/meshery",
  "license": "Apache-2.0",
  "dependencies": {
